{
  "name": "editormind-mcp",
  "version": "1.0.0",
  "description": "AI agent control for Unity Editor via MCP",
  "main": "index.js",
  "type": "commonjs",
  "bin": {
    "editormind-mcp": "./index.js"
  },
  "scripts": {
    "build": "esbuild index.js --bundle --platform=node --target=node18 --outfile=bin/editormind-mcp.js"
  },
  "pkg": {
    "assets": [],
    "targets": [
      "node18-win-x64",
      "node18-macos-arm64",
      "node18-linux-x64"
    ]
  },
  "keywords": [
    "mcp",
    "unity",
    "unity-editor",
    "claude",
    "ai",
    "game-dev"
  ],
  "author": "Raheeb Ahmad",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
